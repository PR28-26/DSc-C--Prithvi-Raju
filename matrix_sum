#include<stdio.h>
int main()
{
  int arr[10][10],b[10][10],sum[10][10];
  int m,n,p,q;
  int i,j;
  printf("\nEnter the number of rows and columns of matrix 1:");
  scanf("%d%d",&m,&n);
  printf("\nEnter the number of rows and columns of matrix 2:");
  scanf("%d%d",&p,&q);
  printf("\n enter The elements of the matrix 1");
  for(i=0;i<m;i++)
  {
    for(j=0;j<n;j++)
    {
       scanf("%d",&arr[i][j]);
    }
  }
  printf("\nThe matrix is:\n");
  for(i=0;i<m;i++)
  {
    for(j=0;j<n;j++)
    {
       printf("%d\t",arr[i][j]);
    }
    printf("\n");
  }
  printf("\n enter The elements of the matrix 2");
  for(i=0;i<p;i++)
  {
    for(j=0;j<q;j++)
    {
       scanf("%d",&b[i][j]);
    }
  }
  printf("\nThe matrix is:\n");
  for(i=0;i<p;i++)
  {
    for(j=0;j<q;j++)
    {
       printf("%d\t",b[i][j]);
    }
    printf("\n");
  }
  if((m==p)&&(p==q))
  {
    for(i=0;i<m;i++)
    {
        for(j=0;j<n;j++)
        {
          sum[i][j]=ar[i][j]+b[i][j];
        }
    }
    printf("\n The sum of matrix 1 and 2 are\n:");
  for(i=0;i<p;i++)
  {
    for(j=0;j<q;j++)
    {
       printf("%d\t",sum[i][j]);
    }
    printf("\n");
  }
  }
  return 0;
}
