#include<stdio.h>
#include<string.h>
int main()
{
    char s[100];
    int i,c=0,n;
    printf("\nEnter a string:");
    scanf("%s",s);
    n=strlen(s);
    for(i=0;i<n/2;i++)
    {
        if((s[i]==s[n-i-1]))
        {
            c+=1;
        }
    }
    if(c==i)
    {
        printf("\nString is a Palindrome");
    }
    else
    {
        printf("\nString is not a palindrome");
    }
    return 0;
}
