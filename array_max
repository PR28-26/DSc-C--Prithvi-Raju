#include<stdio.h>
int main()
{
    int arr[10];
    int n,i,max;
    int found=0;
    printf("\nEnter the number of elements of array:");
    scanf("%d",&n);
    printf("\nEnter the elements of array:");
    for(i=0;i<n;i++)
    {
       scanf("%d",&arr[i]);
    }
    printf("\nThe arrray is");
    for(i=0;i<n;i++)
    {
       printf("\t%d",arr[i]);
    }
    max=arr[0];
    for(i=0;i<n;i++)
    {
        if(arr[i]>max)
        {
            max=arr[i];
        }
    }
    printf("\nThe maximum value in array is %d",max);
    return 0;
}
